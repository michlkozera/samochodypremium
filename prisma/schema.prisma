// --------------------------------------------------------------------------
// Prisma Schema - Samochody Premium
// --------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --------------------------------------------------------------------------
// Status ogloszenia
// --------------------------------------------------------------------------

enum VehicleStatus {
  AVAILABLE // Dostepny
  RESERVED  // Zarezerwowany
  SOLD      // Sprzedany
}

// --------------------------------------------------------------------------
// Rodzaj paliwa
// --------------------------------------------------------------------------

enum FuelType {
  PETROL   // Benzyna
  DIESEL   // Diesel
  HYBRID   // Hybryda (plug-in / mild)
  ELECTRIC // Elektryk
  LPG      // LPG
}

// --------------------------------------------------------------------------
// Skrzynia biegow
// --------------------------------------------------------------------------

enum Transmission {
  AUTOMATIC // Automatyczna
  MANUAL    // Manualna
}

// --------------------------------------------------------------------------
// Typ napedu
// --------------------------------------------------------------------------

enum DriveTrain {
  FWD // Przod
  RWD // Tyl
  AWD // 4x4 / Wszystkie kola
}

// --------------------------------------------------------------------------
// Typ nadwozia
// --------------------------------------------------------------------------

enum BodyType {
  SEDAN       // Sedan
  SUV         // SUV
  COUPE       // Coupe
  CONVERTIBLE // Kabriolet
  HATCHBACK   // Hatchback
  ESTATE      // Kombi
  LIFTBACK    // Liftback
  PICKUP      // Pickup
  VAN         // Van
}

// --------------------------------------------------------------------------
// Rodzaj faktury VAT
// --------------------------------------------------------------------------

enum VatType {
  VAT_23     // Faktura VAT 23%
  VAT_MARGIN // VAT marza
  NONE       // Bez faktury (osoba prywatna)
}

// --------------------------------------------------------------------------
// Stan pojazdu
// --------------------------------------------------------------------------

enum VehicleCondition {
  NEW  // Nowy
  USED // Uzywany
}

// --------------------------------------------------------------------------
// Model pojazdu - glowna tabela ogloszen
// --------------------------------------------------------------------------

model Vehicle {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- Glowne dane ---
  make       String  // Marka (np. Porsche, BMW, Mercedes-Benz)
  model      String  // Model (np. 911, M5, AMG GT)
  generation String? // Generacja / wersja (np. 992, G30)
  year       Int     // Rok produkcji

  // --- Wyglad i nadwozie ---
  bodyType   BodyType? // Typ nadwozia
  color      String?   // Kolor zewnetrzny
  upholstery String?   // Tapicerka (np. Skora Merino, Alcantara)
  doors      Int?      // Liczba drzwi
  seats      Int?      // Liczba miejsc

  // --- Dane techniczne ---
  mileage        Int          // Przebieg w km
  engineCapacity Int?         // Pojemnosc silnika w cm3 (null dla elektrykow)
  power          Int          // Moc w KM
  powerUnit      String       @default("KM") // Jednostka mocy (KM / kW)
  fuelType       FuelType     // Rodzaj paliwa
  transmission   Transmission // Skrzynia biegow
  driveTrain     DriveTrain   // Typ napedu

  // --- Pochodzenie i historia ---
  originCountry      String?          // Kraj pochodzenia
  firstRegistration  DateTime?        // Data pierwszej rejestracji
  firstOwner         Boolean          @default(false) // Pierwszy wlasciciel
  registeredInPoland Boolean          @default(false) // Zarejestrowany w Polsce
  registrationNumber String?          // Numer rejestracyjny
  condition          VehicleCondition @default(USED) // Stan pojazdu
  accidentFree       Boolean          @default(false) // Bezwypadkowy
  serviceHistory     Boolean          @default(false) // Serwisowany w ASO

  // --- Identyfikacja ---
  vin String @unique // Numer VIN (17 znakow, unikalny)

  // --- Finanse ---
  price          Decimal @db.Decimal(12, 2) // Cena
  currency       String  @default("PLN") // Waluta
  vatReclaimable Boolean @default(false) // Faktura VAT 23%
  vatType        VatType @default(NONE) // Rodzaj faktury

  // --- Media i opis ---
  description       String?  @db.Text // Dlugi opis ogloszenia
  youtubeUrl        String? // Link do filmu YouTube dla oferty
  images            String[] // URL-e zdjec (zewnetrzny hosting)
  imagePublicIds    String[] @default([]) // Public IDs z Cloudinary odpowiadajace tablicy images
  primaryImageIndex Int      @default(0) // Indeks zdjecia glownego

  // --- Wyposazenie ---
  features String[] // Lista elementow wyposazenia

  // --- Status ---
  status VehicleStatus @default(AVAILABLE)

  // --- SEO / URL ---
  slug String @unique // Przyjazny URL (np. "porsche-911-carrera-s-2024")

  // --- Indeksy ---
  @@index([status])
  @@index([make, model])
  @@index([year])
  @@index([price])
  @@index([bodyType])
}
